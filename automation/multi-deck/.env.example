# --- YouTube Data API (trend lookup + upload) ---
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:53682/oauth2callback
YOUTUBE_REFRESH_TOKEN=

# --- Claude API (question + catchphrase + title/description generation) ---
ANTHROPIC_API_KEY=

# --- Site under automation ---
SITE_URL=https://starlight-tarot-room.vercel.app

# --- ffmpeg binary path (Windows: full path to ffmpeg.exe if not on PATH) ---
FFMPEG_PATH=ffmpeg

# --- Subtitle font (Windows default: 맑은 고딕). 다른 한글 폰트 쓰려면 .ttf 전체 경로 지정 ---
SUBTITLE_FONT_PATH=C:/Windows/Fonts/malgunbd.ttf

# --- Pipeline behavior ---
TARGET_REGION=KR
PUBLISH_DELAY_HOURS=24
